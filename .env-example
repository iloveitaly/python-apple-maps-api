# Environment variables for the project

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
export LOG_LEVEL=DEBUG

# Apple Maps Server API credentials
# Get these from https://developer.apple.com/account/resources/authkeys/list
export APPLE_MAPS_TEAM_ID=""
export APPLE_MAPS_KEY_ID=""
# Paste the full PEM contents of your .p8 key file (including BEGIN/END lines)
export APPLE_MAPS_P8_KEY=""
